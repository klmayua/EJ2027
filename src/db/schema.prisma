generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EXECUTIVE
  NATIONAL_COMMAND
  CHAPTER_LEAD
  CHAPTER_EXECUTIVE
  PARTNER
  DONOR
  CREATOR
  VOLUNTEER
  MEMBER
  MODERATOR
  ANALYST
  GUEST
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum VolunteerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  FLAGGED
}

enum ProjectStatus {
  DRAFT
  REVIEW
  LIVE
  FUNDED
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum DonationStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  FLAGGED
}

enum WalletStatus {
  ACTIVE
  LOCKED
  FROZEN
  CLOSED
}

enum TransactionType {
  CREDIT
  DEBIT
  REWARD
  DONATION
  PAYOUT
  REFUND
}

enum RewardType {
  BADGE
  POINT
  CASH
  TOKEN
  RECOGNITION
}

enum MessageType {
  DIRECT
  CHANNEL
  BROADCAST
  SYSTEM
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TrustLevel {
  LOW
  FAIR
  GOOD
  HIGH
  ELITE
}

enum SentimentType {
  POSITIVE
  NEUTRAL
  NEGATIVE
  VOLATILE
}

enum ChapterTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

// ============================================================
// USER & IDENTITY MODELS
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?
  passwordHash  String
  role         UserRole   @default(MEMBER)
  emailVerified DateTime?
  phoneVerified DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?
  deletedAt   DateTime?
  
  profile        Profile?
  wallets       Wallet[]
  donations     Donation[]
  volunteer     Volunteer?
  memberships  ChapterMember[]
  messagesSent  Message[]    @relation("SentMessages")
  messagesRecv  Message[]    @relation("ReceivedMessages")
  notifications Notification[]
  audits       Audit[]
  trustHistory  TrustHistory[]

  @@index([email])
  @@index([role])
  @@index([createdAt])
  @@index([deletedAt])
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName   String
  lastName    String
  displayName String?
  avatar      String?
  bio         String?
  location    String?
  state       String?
  lga         String?
  chapterId   String?
  trustScore  Int      @default(50)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  badges      VolunteerBadge[]
  skills      VolunteerSkill[]

  @@index([state])
  @@index([lga])
  @@index([trustScore])
}

// ============================================================
// VOLUNTEER MODELS
// ============================================================

model Volunteer {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId    String   @unique
  profile      Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  chapterId    String?
  chapter     Chapter? @relation(fields: [chapterId], references: [id])
  status      VolunteerStatus @default(ACTIVE)
  hoursLogged  Int      @default(0)
  tasksCompleted Int    @default(0)
  deletedAt   DateTime?
  joinedAt   DateTime @default(now())
  tasks       VolunteerTask[]
  trainings  Training[]

  @@index([chapterId])
  @@index([status])
}

model VolunteerBadge {
  id          String   @id @default(cuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  description String?
  icon        String?
  awardedAt   DateTime @default(now())
}

model VolunteerSkill {
  id        String   @id @default(cuid())
  profileId String
  profile  Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name     String
  level    String   @default("BEGINNER")
}

model VolunteerTask {
  id          String   @id @default(cuid())
  volunteerId String
  volunteer  Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status     String   @default("PENDING")
  dueDate    DateTime?
  completedAt DateTime?
  createdAt  DateTime @default(now())
}

model Training {
  id          String   @id @default(cuid())
  volunteerId String
  volunteer  Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  title       String
  completedAt DateTime @default(now())
}

// ============================================================
// CHAPTER MODELS
// ============================================================

model Chapter {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  state      String
  lga        String?
  description String?
  logo       String?
  coverImage String?
  tier       ChapterTier @default(BRONZE)
  score      Int      @default(0)
  status     String   @default("ACTIVE")
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  members    ChapterMember[]
  volunteers Volunteer[]
  projects   Project[]
  events    Event[]
  metrics    ChapterMetric[]

  @@index([slug])
  @@index([state])
  @@index([status])
}

model ChapterMember {
  id        String   @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapterId String
  chapter  Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  role     String   @default("MEMBER")
  joinedAt  DateTime @default(now())
  
  @@unique([userId, chapterId])
}

model ChapterMetric {
  id          String   @id @default(cuid())
  chapterId  String
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  metric    String
  value     Float
  period    String
  createdAt DateTime @default(now())
}

// ============================================================
// PROJECT MODELS
// ============================================================

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  coverImage  String?
  state      String?
  lga        String?
  status     ProjectStatus @default(DRAFT)
  targetAmount Float     @default(0)
  raisedAmount Float     @default(0)
  startDate  DateTime?
  endDate   DateTime?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  chapterId  String?
  chapter   Chapter? @relation(fields: [chapterId], references: [id])
  milestones ProjectMilestone[]
  updates   ProjectUpdate[]
  donations Donation[]
  sponsors  Sponsor[]
  evidence  ProjectEvidence[]
  beneficiaries ProjectBeneficiary[]

  @@index([slug])
  @@index([status])
  @@index([chapterId])
  @@index([createdAt])
}

model ProjectMilestone {
  id          String   @id @default(cuid())
  projectId   String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title      String
  description String?
  targetDate DateTime?
  completed  Boolean  @default(false)
  completedAt DateTime?
}

model ProjectUpdate {
  id          String   @id @default(cuid())
  projectId   String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title      String
  content    String
  images     String[]
  createdAt  DateTime  @default(now())
}

model ProjectEvidence {
  id          String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String
  url       String
  caption   String?
  uploadedAt DateTime  @default(now())
}

model ProjectBeneficiary {
  id          String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  location  String?
  count     Int      @default(1)
  createdAt  DateTime  @default(now())
}

// ============================================================
// DONATION MODELS
// ============================================================

model Donation {
  id          String      @id @default(cuid())
  userId      String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String?
  project    Project?    @relation(fields: [projectId], references: [id])
  amount     Float
  currency   String      @default("NGN")
  status     DonationStatus @default(PENDING)
  paymentMethod String?
  reference  String?     @unique
  donorName  String?
  isAnonymous Boolean   @default(false)
  deletedAt  DateTime?
  createdAt  DateTime    @default(now())

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

model Sponsor {
  id          String   @id @default(cuid())
  projectId   String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  logo       String?
  tier       String   @default("BRONZE")
  amount     Float?
  startDate  DateTime?
  endDate   DateTime?
}

// ============================================================
// PARTNER MODELS
// ============================================================

model Partner {
  id          String   @id @default(cuid())
  name        String
  logo       String?
  website    String?
  type       String
  status     String   @default("ACTIVE")
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
}

model PartnerCampaign {
  id          String   @id @default(cuid())
  partnerId  String
  campaignId String
  budget    Float?
  status    String   @default("ACTIVE")
  createdAt  DateTime  @default(now())
}

// ============================================================
// WALLET MODELS
// ============================================================

model Wallet {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Float    @default(0)
  currency  String   @default("NGN")
  status    WalletStatus @default(ACTIVE)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  transactions Transaction[]
  
  @@unique([userId])
  @@index([userId])
  @@index([status])
}

model Transaction {
  id          String   @id @default(cuid())
  walletId    String
  wallet     Wallet  @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type       TransactionType
  amount     Float
  description String?
  reference  String?   @unique
  createdAt  DateTime @default(now())

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
}

model RewardLedger {
  id          String   @id @default(cuid())
  userId     String
  type       RewardType
  amount    Float
  reference String?
  createdAt DateTime  @default(now())
}

// ============================================================
// CONTENT MODELS
// ============================================================

model Story {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  excerpt     String?
  coverImage  String?
  author      String?
  category   String?
  tags        String[]
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([published])
  @@index([featured])
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  coverImage String?
  startDate  DateTime?
  endDate   DateTime?
  status     String   @default("ACTIVE")
  createdAt  DateTime  @default(now())
}

model Event {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  location    String?
  startDate   DateTime
  endDate     DateTime?
  coverImage String?
  status      String   @default("UPCOMING")
  deletedAt   DateTime?
  chapterId  String?
  chapter   Chapter? @relation(fields: [chapterId], references: [id])

  @@index([slug])
  @@index([startDate])
  @@index([status])
}

// ============================================================
// MESSAGING MODELS
// ============================================================

model Message {
  id        String   @id @default(cuid())
  senderId  String
  sender    User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver  User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  content   String
  type     MessageType @default(DIRECT)
  readAt   DateTime?
  createdAt DateTime  @default(now())
}

model Channel {
  id          String   @id @default(cuid())
  name        String
  description String?
  type       String   @default("PUBLIC")
  createdAt  DateTime  @default(now())
  members    ChannelMember[]
  messages   ChannelMessage[]
}

model ChannelMember {
  id        String   @id @default(cuid())
  channelId String
  channel  Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String
  role     String   @default("MEMBER")
  joinedAt  DateTime @default(now())
  
  @@unique([channelId, userId])
}

model ChannelMessage {
  id        String   @id @default(cuid())
  channelId String
  channel  Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String
  content   String
  createdAt DateTime @default(now())
}

model Broadcast {
  id          String   @id @default(cuid())
  title       String
  content     String
  type        String   @default("ANNOUNCEMENT")
  sentBy      String?
  sentAt      DateTime @default(now())
  scheduledAt DateTime?
  status     String   @default("SENT")
  recipients BroadcastRecipient[]
}

model BroadcastRecipient {
  id           String   @id @default(cuid())
  broadcastId  String
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  userId      String
  readAt      DateTime?
  
  @@unique([broadcastId, userId])
}

model Conversation {
  id          String   @id @default(cuid())
  name        String?
  type       String   @default("DIRECT")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  members   ConversationMember[]
  messages   ConversationMessage[]
}

model ConversationMember {
  id             String        @id @default(cuid())
  conversationId String
  conversation  Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  role          String       @default("MEMBER")
  joinedAt       DateTime      @default(now())
  
  @@unique([conversationId, userId])
}

model ConversationMessage {
  id             String        @id @default(cuid())
  conversationId String
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  content        String
  readAt         DateTime?
  createdAt      DateTime      @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

// ============================================================
// REPORTING & COMPLIANCE
// ============================================================

model Report {
  id          String   @id @default(cuid())
  type        String
  title       String
  description String
  status     String   @default("PENDING")
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
}

model Audit {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  entity     String?
  entityId   String?
  metadata   String?
  ipAddress  String?
  userAgent String?
  sessionId String?
  requestId String?
  severity  String?
  source    String?
  createdAt  DateTime  @default(now())
}

model WhistleblowerReport {
  id          String   @id @default(cuid())
  title      String
  description String
  type       String
  status     String   @default("CONFIDENTIAL")
  filedAt    DateTime  @default(now())
  resolvedAt DateTime?
}

// ============================================================
// INTELLIGENCE MODELS
// ============================================================

model TrustMetric {
  id        String   @id @default(cuid())
  metric    String
  value    Float
  period   String
  createdAt DateTime  @default(now())
}

model TrustHistory {
  id          String   @id @default(cuid())
  userId     String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  previousScore Int
  newScore    Int
  reason     String?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
}

model SentimentSignal {
  id        String   @id @default(cuid())
  source    String
  sentiment Float
  topic    String?
  content  String?
  type     SentimentType @default(NEUTRAL)
  createdAt DateTime  @default(now())

  @@index([source])
  @@index([createdAt])
}

model OSINTReport {
  id          String   @id @default(cuid())
  title      String
  summary   String
  source    String?
  confidence Float?
  createdAt DateTime  @default(now())

  @@index([createdAt])
}

model OSINTSource {
  id          String   @id @default(cuid())
  name        String
  type       String
  url        String?
  status     String   @default("ACTIVE")
  lastSyncAt  DateTime?
  reports    OSINTReport[]
  createdAt  DateTime  @default(now())
}

model NarrativeCluster {
  id          String   @id @default(cuid())
  topic       String
  sentiment  Float?
  volume     Int      @default(0)
  keywords   String[]
  signals    SentimentSignal[]
  createdAt  DateTime  @default(now())
}

model InfluenceActor {
  id          String   @id @default(cuid())
  name        String
  handle      String?
  platform    String?
  type        String?
  followers   Int      @default(0)
  riskScore   Float?
  createdAt   DateTime  @default(now())
}

model TrendSignal {
  id          String   @id @default(cuid())
  topic       String
  sentiment  Float
  volume     Int
  velocity   Float?
  createdAt  DateTime  @default(now())
}

model RiskAlert {
  id          String   @id @default(cuid())
  level       RiskLevel
  title       String
  description String
  topic      String?
  source     String?
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
}

model AIAssistantSession {
  id          String   @id @default(cuid())
  userId     String
  messages   Json
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// ============================================================
// CMS MODELS
// ============================================================

model Page {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String?
  template    String?
  status     String   @default("DRAFT")
  publishedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Section {
  id          String   @id @default(cuid())
  pageId     String
  page       Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  title      String?
  order      Int      @default(0)
  blocks     Block[]
}

model Block {
  id          String   @id @default(cuid())
  sectionId  String
  section   Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  type       String
  content    String?
  order      Int      @default(0)
}

model MediaAsset {
  id          String   @id @default(cuid())
  name        String
  url        String
  type       String
  size       Int?
  uploadedBy String?
  deletedAt   DateTime?
  createdAt  DateTime  @default(now())
}

model PressRelease {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content    String
  source     String?
  publishedAt DateTime?
  status     String   @default("DRAFT")
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
}

model SiteAnnouncement {
  id          String   @id @default(cuid())
  title       String
  content    String
  type       String   @default("INFO")
  active     Boolean  @default(true)
  startsAt   DateTime?
  endsAt    DateTime?
  createdAt  DateTime  @default(now())
}

// ============================================================
// STRATEGIC MODELS
// ============================================================

model Creator {
  id          String   @id @default(cuid())
  name        String
  handle      String   @unique
  avatar      String?
  bio         String?
  platform    String?
  followers   Int      @default(0)
  status     String   @default("ACTIVE")
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  submissions CreatorSubmission[]
}

model CreatorSubmission {
  id          String   @id @default(cuid())
  creatorId   String
  creator    Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  title      String
  content    String
  type       String   @default("STORY")
  status     String   @default("PENDING")
  reviewedAt DateTime?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
}

model Townhall {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  startDate  DateTime
  endDate    DateTime?
  status    String   @default("UPCOMING")
  createdAt  DateTime  @default(now())
}

model Discussion {
  id          String   @id @default(cuid())
  title       String
  content    String
  category   String?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  comments   Comment[]
}

model Comment {
  id           String     @id @default(cuid())
  discussionId String
  discussion   Discussion  @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  content      String
  parentId     String?
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())
}

model Poll {
  id           String     @id @default(cuid())
  question    String
  options     PollOption[]
  status      String     @default("ACTIVE")
  expiresAt   DateTime?
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
}

model PollOption {
  id      String @id @default(cuid())
  pollId   String
  poll    Poll    @relation(fields: [pollId], references: [id], onDelete: Cascade)
  text    String
  votes   Int    @default(0)
}

model DiasporaMember {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  country    String?
  chapterId   String?
  status     String   @default("ACTIVE")
  joinedAt   DateTime  @default(now())
}

model VolunteerReferral {
  id          String   @id @default(cuid())
  referrerId  String
  refereeId  String
  status    String   @default("PENDING")
  createdAt  DateTime  @default(now())
}